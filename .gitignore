# === Python ===
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
eggs/
.eggs/
parts/
sdist/
var/
pip-wheel-metadata/
*.egg-info/
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/
venv.bak/
.python-version

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# MyPy
.mypy_cache/

# Pyre
.pyre/

# === Rust ===
# Build output
/target/

# Generated by Cargo (usually commit Cargo.lock for apps; ignore if library)
# Uncomment the next line if you prefer to ignore Cargo.lock
# Cargo.lock

# Cargo package cache and git checkouts
.cargo/

# Backup files
**/*.rs.bk

# === Docker ===
# Env files (may contain secrets)
.env
.env.*

# Docker Compose overrides and runtime artifacts
docker-compose.override.yml
docker-compose.override.yaml
docker-compose.*.yml
docker-compose.*.yaml
.docker/

# Docker build logs
docker-compose.log

# === Editor / OS ===
# VS Code
.vscode/

# JetBrains IDEs
.idea/

# macOS
.DS_Store

# Generic
*.log
.cache/
coverage/
node_modules/

# Secrets and local configs
*.key
*.pem
secrets.yml
*.secret
